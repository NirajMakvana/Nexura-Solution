PORT=5002
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/nexura-solution
JWT_SECRET=your-super-secret-jwt-key-here
FRONTEND_URL=http://localhost:5173

# Company Details
COMPANY_NAME=Nexura Solutions
COMPANY_EMAIL=your-company-email@gmail.com
COMPANY_PHONE=+91 XXXXX XXXXX
COMPANY_WHATSAPP=+91 XXXXX XXXXX
COMPANY_ADDRESS=Your Company Address

# Email / SMTP Configuration
# For Gmail: use App Password from https://myaccount.google.com/apppasswords
# Leave blank to use Ethereal (test mode - preview links logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL="Your Company <noreply@yourcompany.com>"
ADMIN_EMAIL=your-admin-email@gmail.com
