{
  "name": "nexura-solution",
  "version": "1.0.0",
  "description": "Integrated Enterprise Operations & HRMS Suite",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "hrms",
    "enterprise",
    "saas",
    "react",
    "express",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT"
}